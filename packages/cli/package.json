{
  "name": "veye",
  "version": "0.1.0",
  "type": "module",
  "description": "Doc-freshness engine — measure, surface, and gate on documentation staleness",
  "keywords": [
    "docs",
    "documentation",
    "freshness",
    "gate",
    "ci",
    "lint"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/veye/veye.git"
  },
  "homepage": "https://github.com/veye/veye",
  "bugs": {
    "url": "https://github.com/veye/veye/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "bin": {
    "veye": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun build src/cli.ts --outfile dist/cli.js --target=bun"
  },
  "dependencies": {
    "@veye/core": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5.8.0"
  }
}
