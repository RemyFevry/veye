{
  "name": "@color-sunset/veye",
  "version": "0.1.1",
  "type": "module",
  "description": "Doc-freshness engine — measure, surface, and gate on documentation staleness",
  "keywords": [
    "docs",
    "documentation",
    "freshness",
    "gate",
    "ci",
    "lint"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/RemyFevry/veye.git"
  },
  "homepage": "https://github.com/RemyFevry/veye",
  "bugs": {
    "url": "https://github.com/RemyFevry/veye/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "veye": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/cli.ts --outfile dist/cli.js --target=node && sed -i '' '1s|.*|#!/usr/bin/env node|' dist/cli.js",
    "dev": "bun run src/cli.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {}
}
